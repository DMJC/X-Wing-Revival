CXX      = g++
CXXFLAGS = -std=c++17 -O2 -Wall -Wextra -Wno-unused-parameter \
           $(shell pkg-config --cflags gtkmm-3.0)
LDFLAGS  = $(shell pkg-config --libs gtkmm-3.0)
TARGET   = mission-editor

SRCS = main.cpp MainWindow.cpp MissionCanvas.cpp
OBJS = $(SRCS:.cpp=.o)

.PHONY: all clean

all: $(TARGET)

$(TARGET): $(OBJS)
	$(CXX) -o $@ $^ $(LDFLAGS)

%.o: %.cpp
	$(CXX) $(CXXFLAGS) -c -o $@ $<

# Header dependencies (generated by g++ -MM would be ideal; hand-listed here)
main.o:          main.cpp MainWindow.h MissionData.h MissionCanvas.h
MainWindow.o:    MainWindow.cpp MainWindow.h Dialogs.h MissionData.h MissionCanvas.h
MissionCanvas.o: MissionCanvas.cpp MissionCanvas.h MissionData.h

clean:
	rm -f $(OBJS) $(TARGET)
